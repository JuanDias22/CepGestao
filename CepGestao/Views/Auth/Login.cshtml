@{
    ViewData["Title"] = "Login";
}

<h2>Login</h2>

@if (ViewBag.Erro != null)
{
    <div style="color:red;">
        @ViewBag.Erro
    </div>
}

<form method="post">

    <div>
        <label>Usuário</label>
        <br />
        <input type="text" name="username" />
    </div>

    <br />

    <div>
        <label>Senha</label>
        <br />
        <input type="password" name="senha" />
    </div>

    <br />

    <button type="submit">
        Entrar
    </button>

</form>