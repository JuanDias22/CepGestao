@model CepGestao.Models.Endereco

<h2>Editar Endereço</h2>

<form method="post">

    <input class="form-control" type="hidden" name="Id" value="@Model.Id" />
    <input class="form-control" type="hidden" name="UsuarioId" value="@Model.UsuarioId" />

    <div>
        <label>CEP</label>
        <input class="form-control" type="text" name="Cep" value="@Model.Cep" />
    </div>

    <p> 
    <div>
        <label>Logradouro</label>
        <input class="form-control" type="text" name="Logradouro" value="@Model.Logradouro" />
    </div>
    </p>

    <p> 
    <div>
        <label>Complemento</label>
        <input class="form-control" type="text" name="Complemento" value="@Model.Complemento" />
    </div>
    </p>

    <p> 
    <div>
        <label>Bairro</label>
        <input class="form-control" type="text" name="Bairro" value="@Model.Bairro" />
    </div>
    </p>

    <p> 
    <div>
        <label>Cidade</label>
        <input class="form-control" type="text" name="Cidade" value="@Model.Cidade" />
    </div>
    </p>

    <p> 
    <div>
        <label>UF</label>
        <input class="form-control" type="text" name="Uf" value="@Model.Uf" />
    </div>
    </p>

    <p> 
    <div>
        <label>Número</label>
        <input class="form-control" type="text" name="Numero" value="@Model.Numero" />
    </div>
    </p>  

    <button type="submit">
        Salvar Alterações
    </button>

</form>
