@model List<CepGestao.Models.Endereco>

<h2>Endereços</h2>

<a href="/Endereco/Create">
    Novo Endereço
</a>

<table border="1" cellpadding="10">

    <tr>
        <th>Ações</th>
        <th>CEP</th>
        <th>Logradouro</th>
        <th>Número</th>
        <th>Cidade</th>
        <th>UF</th>
    </tr>

    @foreach (var item in Model)
    {

        <tr>

            <td>
                <a href="/Endereco/Edit/@item.Id">
                    Editar
                </a>

                |

                <a href="/Endereco/Delete/@item.Id">
                    Excluir
                </a>
            </td>
                       
            <td>@item.Cep</td>
            <td>@item.Logradouro</td>
            <td>@item.Numero</td>
            <td>@item.Cidade</td>
            <td>@item.Uf</td>
        </tr>
    }

</table>
