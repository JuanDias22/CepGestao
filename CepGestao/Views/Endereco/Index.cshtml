@model List<CepGestao.Models.Endereco>

@{
    ViewData["Title"] = "Endereços";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="fw-bold mb-1">Meus Endereços</h2>

        <p class="text-muted mb-0">
            Gerencie seus endereços cadastrados
        </p>
    </div>

    <div class="d-flex gap-2">

        <a href="/Endereco/Create"
               class="btn btn-primary">
            + Novo Endereço
        </a>

        <a href="/Endereco/ExportarCsv"
               class="btn btn-success">
            Exportar CSV
        </a>

    </div>

</div>

<div class="card border-0 shadow-sm">

    <div class="card-body p-0">

        <table class="table table-hover align-middle mb-0">

            <thead class="table-light">

                <tr>

                    <th class="ps-4">CEP</th>
                    <th>Logradouro</th>
                    <th>Número</th>
                    <th>Cidade</th>
                    <th>UF</th>

                    <th class="text-center" width="180">
                        Ações
                    </th>

                </tr>

            </thead>

            <tbody>

                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="6"
                            class="text-center py-5 text-muted">

                            Nenhum endereço cadastrado.

                        </td>
                    </tr>
                }

                @foreach (var item in Model)
                {
                    <tr>

                        <td class="ps-4 fw-semibold">
                            @item.Cep
                        </td>

                        <td>
                            @item.Logradouro
                        </td>

                        <td>
                            @item.Numero
                        </td>

                        <td>
                            @item.Cidade
                        </td>

                        <td>
                            <span class="badge bg-secondary">
                                @item.Uf
                            </span>
                        </td>

                        <td>

                            <div class="d-flex justify-content-center gap-2">

                                <a href="/Endereco/Edit/@item.Id"
                                       class="btn btn-outline-warning btn-sm">

                                    Editar

                                </a>

                                <a href="/Endereco/Delete/@item.Id"
                                       class="btn btn-outline-danger btn-sm">

                                    Excluir

                                </a>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

<div class="mt-4">

    <a class="btn btn-outline-dark"
           href="/Auth/Logout">

        Sair

    </a>

</div>